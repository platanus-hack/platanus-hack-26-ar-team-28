# Vibefence local agent — environment overrides.
#
# This file documents the variables the agent reads. The CLI doesn't auto-load
# .env files; either `export` (POSIX) / `$env:NAME = "..."` (PowerShell) before
# running, or copy lines into your shell profile.

# Where the cloud dashboard lives.
#   - Production demo:  https://vibefence-black.vercel.app
#   - Local dev:        http://localhost:3000
# After the first `vibefence pair`, this is also persisted in
# ~/.vibefence/config.json and reused by `vibefence start`.
VIBEFENCE_CLOUD_URL="https://vibefence-black.vercel.app"
